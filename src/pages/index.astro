---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactLink from "../components/ContactLink.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.contact-links {
				margin-top: 2em;
			}
		</style>
	</head>
	<body>
		<Header title={SITE_TITLE} />
		<main>
			<p>👋 I'm Jonathan, a software engineer living in Brooklyn, NY.</p>

			<p>
				I’ve developed mobile applications and made large teams of engineers more productive at Slack and Block. These days, I’m most interested in programming languages, build systems, and developer tools. And verification -- if an LLM is writing my app, how do I prove it works?
			</p>

			<p>
				I'm open to work. Need a project migrated to build with <a href="https://bazel.build/">bazel</a>?
				You can reach me at <a href="mailto:jschear@jschear.dev"
					>jschear@jschear.dev</a
				>.
			</p>
		</main>

		<div class="contact-links">
			<ContactLink href="https://github.com/jschear">github</ContactLink>
			<ContactLink href="https://www.linkedin.com/in/jschear/">
				linkedin
			</ContactLink>
			<ContactLink href="https://bsky.app/profile/jschear.dev">
				bluesky
			</ContactLink>
			<ContactLink href="https://www.instagram.com/jschear_">
				instagram
			</ContactLink>
			<ContactLink
				href="https://www.goodreads.com/user/show/46973738-jonathan-schear"
			>
				goodreads
			</ContactLink>
		</div>
		<Footer />
	</body>
</html>
